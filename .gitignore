# macOS
.DS_Store

# Editor
.vscode/
.idea/
*.swp

# Logs
*.log

# Local env (each subproject имеет свой .gitignore)
.env.local

# Claude Code — локальные логи хуков и local-only настройки
.claude/memory/logs/
.claude/settings.local.json
.claude/secrets/

# graphify — артефакты восстановимы из исходников, не коммитим (избегаем loop с post-commit hook)
graphify-out/

# Playwright скриншоты — локально, не коммитить
screen/

# Playwright MCP — auto-snapshots от browser tools, не коммитить
.playwright-mcp/

# Chat logs — curated session summaries, локальные, не коммитить
chat/

# Scheduled tasks lock — runtime artifact
.claude/scheduled_tasks.lock

# Heavy media assets — не коммитим исходники, только мета и README
assets/photos/
assets/videos/
assets/temp/
assets/services/**/*.png
assets/services/**/*.webp
assets/services/**/*.jpg

# Локальные эксперименты / внешние скилы (не часть проекта)
.agents/
skills-lock.json
.tmp-*
__pycache__/
*.pyc
