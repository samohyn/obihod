# Database
DATABASE_URI=postgres://obikhod:obikhod_dev@localhost:5432/obikhod

# Local admin bootstrap (запускается через `pnpm seed:admin` после `pnpm db:up`)
ADMIN_EMAIL=admin@obikhod.local
ADMIN_PASSWORD=obikhod_dev_admin
TEST_USER_EMAIL=test@obikhod.local
TEST_USER_PASSWORD=obikhod_dev_test

# Payload
PAYLOAD_SECRET=change-me-to-random-32-byte-string

# Site
SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Revalidation webhook secret (Payload → Next.js)
REVALIDATE_SECRET=change-me-to-random-string

# IndexNow API key (32 hex chars)
INDEXNOW_KEY=change-me-32-hex-chars

# Яндекс.Метрика — id счётчика (публичный, уходит в клиентский бандл)
NEXT_PUBLIC_YANDEX_METRIKA_ID=108715562

# ─── SEO data sources (EPIC-SEO-COMPETE-3) ────────────────────────────────────
# Server-only, не в клиентский бандл. Operator передаёт вручную в .env.local.
#
# Keys.so — Яндекс/Google semantic data (used by seosite/scripts/keysso_*.py).
# Получить: личный кабинет keys.so → Программный интерфейс → Сгенерировать токен.
# При утечке в чате — РЕГЕНЕРАЦИЯ обязательна.
# KEYSO_API_KEY=
#
# Just-Magic — кластеризатор семантического ядра (US-1 fallback от TF-IDF).
# Получить: just-magic.org → API. При утечке — регенерация.
# JUSTMAGIC_API_KEY=
#
# Topvisor — мониторинг позиций (US-10 weekly snapshot). User ID + token.
# Получить: topvisor.com → Настройки → API. При утечке — регенерация.
# TOPVISOR_API_KEY=
# TOPVISOR_USER_ID=
# ─────────────────────────────────────────────────────────────────────────────

# S3 (заполнить после решения по провайдеру — Beget S3 / YOS / Selectel)
# S3_ENDPOINT=
# S3_REGION=
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# Claude API (для фото→смета, M2)
# ANTHROPIC_API_KEY=

# fal.ai (server-only, генерация изображений — hero/OG/case-viz/blog-cover)
# FAL_KEY=

# Telegram Bot (PAN-9, для magic link admin login + US-8 leads notifications)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_WEBHOOK_SECRET=
# OPERATOR_EMAIL=samohingeorgy@gmail.com
# US-8 lead capture Telegram notifications (operator action — separate task):
#   1) Создать бота через @BotFather → TELEGRAM_BOT_TOKEN
#   2) Получить chat_id через @RawDataBot → TELEGRAM_OPERATOR_CHAT_ID
#   Без этих vars лиды сохраняются в БД, но Telegram-уведомление пропускается
#   (soft-no-op с console.warn, не ломает /api/leads).
# TELEGRAM_OPERATOR_CHAT_ID=

# Email SMTP (PAN-10, для magic link email fallback — Beget или transactional ESP).
# КРИТИЧНО: значения с пробелами оборачивай в double quotes — иначе bash при
# `set -a; . shared/.env` парсит как присвоение + команду (incident 2026-04-28
# deploy.yml exit 127 — `admin: command not found`).
# SMTP_HOST=smtp.beget.com
# SMTP_PORT=587
# SMTP_USER=noreply@obikhod.ru
# SMTP_PASS=
# SMTP_FROM_NAME="Обиход admin"
# SMTP_FROM_EMAIL=noreply@obikhod.ru

# PANEL-AUTH-2FA — TOTP encryption key для шифрования 2FA secret в БД.
# Сгенерируй один раз для каждого окружения:
#   openssl rand -base64 32
# КРИТИЧНО: double quotes обязательны (значение содержит +/= base64-символы).
# При утечке — rotate (см. site/lib/auth/totp/README.md).
TOTP_ENCRYPTION_KEY="REPLACE_WITH_BASE64_32BYTES_FROM_OPENSSL_RAND"

# ─── STAGING-only (staging.obikhod.ru) ────────────────────────────────────────
# Файл: /opt/obikhod-staging/shared/.env на VPS, НЕ commit. Управляется do.
# Operator decisions 2026-05-02:
#   1) Telegram bot полностью OFF на staging — TELEGRAM_ENABLED=false.
#   2) Я.Метрика OFF — NEXT_PUBLIC_YANDEX_METRIKA_ID пустая (не загрязнять prod).
#   3) basic-auth gate — credentials в /etc/nginx/.htpasswd-staging
#      (логин: obihod-staging, пароль передан оператору приватно).
#   4) noindex/nofollow — двойной слой: nginx X-Robots-Tag + meta-tag в HTML.
# Подробности: team/devops/staging-plan.md
# ─────────────────────────────────────────────────────────────────────────────
# APP_ENV=staging
# NEXT_PUBLIC_SITE_URL=https://staging.obikhod.ru
# NEXT_PUBLIC_YANDEX_METRIKA_ID=    # пусто — счётчик отключён
# TELEGRAM_ENABLED=false
# NEXT_PUBLIC_ROBOTS_DIRECTIVE=noindex,nofollow
# SENTRY_ENVIRONMENT=staging
# PORT=3001                          # отделён от prod (3000)
