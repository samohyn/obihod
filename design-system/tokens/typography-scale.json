{
  "$schema": "https://tokens.studio/schema.json",
  "$source": "site/app/globals.css классы .h-display .h-xl .h-l .h-m .h-s .lead .eyebrow",
  "$note": "Типографическая шкала marketing. Размеры — clamp(mobile, vw-scale, desktop) — плавное масштабирование, не резкий breakpoint. Display/H-XL/H-L — только для marketing, в admin и plain text используется body 17px.",
  "font-family": {
    "display": { "value": "var(--font-golos-text), 'Inter', system-ui, sans-serif", "description": "Golos Text — разработан для кириллицы, хорошо работает в heavy weights" },
    "sans": { "value": "var(--font-golos-text), 'Inter', system-ui, sans-serif" },
    "mono": { "value": "var(--font-jetbrains-mono), ui-monospace, monospace", "description": "Цены, ID заявок, технические строки. tabular-nums обязательно." }
  },
  "scale": {
    "display": {
      "$class": ".h-display",
      "font-family": "{font-family.display}",
      "font-weight": { "value": "700" },
      "font-size": { "value": "clamp(48px, 8vw, 96px)" },
      "line-height": { "value": "0.96" },
      "letter-spacing": { "value": "-0.035em" },
      "usage": "Hero H1 на главной. Только 1 на страницу. Text-wrap: balance."
    },
    "h-xl": {
      "$class": ".h-xl",
      "font-weight": { "value": "700" },
      "font-size": { "value": "clamp(36px, 6vw, 64px)" },
      "line-height": { "value": "1.02" },
      "letter-spacing": { "value": "-0.03em" },
      "usage": "H1 на внутренних страницах услуг/районов"
    },
    "h-l": {
      "$class": ".h-l",
      "font-weight": { "value": "600" },
      "font-size": { "value": "clamp(28px, 4vw, 44px)" },
      "line-height": { "value": "1.08" },
      "letter-spacing": { "value": "-0.025em" },
      "usage": "H2 — заголовки секций"
    },
    "h-m": {
      "$class": ".h-m",
      "font-weight": { "value": "600" },
      "font-size": { "value": "clamp(22px, 2.5vw, 28px)" },
      "line-height": { "value": "1.2" },
      "letter-spacing": { "value": "-0.015em" },
      "usage": "H3 — заголовки карточек, подсекций"
    },
    "h-s": {
      "$class": ".h-s",
      "font-weight": { "value": "600" },
      "font-size": { "value": "20px" },
      "line-height": { "value": "1.25" },
      "letter-spacing": { "value": "-0.01em" },
      "usage": "H4 — мини-заголовки в карточках, таблицах"
    },
    "lead": {
      "$class": ".lead",
      "font-size": { "value": "clamp(17px, 1.8vw, 22px)" },
      "line-height": { "value": "1.45" },
      "color": { "value": "{color.ink-soft}" },
      "usage": "Подзаголовок под H1/H2, описание секции. Text-wrap: pretty."
    },
    "body": {
      "$note": "Body = html/body style в globals.css",
      "font-family": "{font-family.sans}",
      "font-weight": { "value": "400" },
      "font-size": { "value": "17px" },
      "line-height": { "value": "1.55" },
      "color": { "value": "{color.ink}" },
      "usage": "Основной текст по умолчанию. 17px — на 1px больше «стандартного» 16 для лучшей читаемости на mobile (Android default font-size 16 работает на среднем зрении плохо)"
    },
    "body-sm": {
      "font-family": "{font-family.sans}",
      "font-weight": { "value": "400" },
      "font-size": { "value": "15px" },
      "line-height": { "value": "1.5" },
      "usage": "Меньший body — footer, capitons под фото"
    },
    "eyebrow": {
      "$class": ".eyebrow",
      "font-family": "{font-family.mono}",
      "font-size": { "value": "12px" },
      "letter-spacing": { "value": "0.12em" },
      "text-transform": { "value": "uppercase" },
      "font-weight": { "value": "500" },
      "color": { "value": "{color.muted}" },
      "usage": "Надзаголовок над H1/H2 — номер секции, категория. Brevity ≤ 3 слов."
    },
    "label": {
      "font-family": "{font-family.sans}",
      "font-size": { "value": "14px" },
      "font-weight": { "value": "500" },
      "line-height": { "value": "1.3" },
      "letter-spacing": { "value": "-0.005em" },
      "usage": "Label у полей формы, chip, кнопки"
    },
    "caption": {
      "font-family": "{font-family.sans}",
      "font-size": { "value": "12px" },
      "font-weight": { "value": "400" },
      "line-height": { "value": "1.4" },
      "color": { "value": "{color.muted}" },
      "usage": "Helper text под полем, подпись под фото"
    },
    "mono": {
      "$class": ".mono .tnum",
      "font-family": "{font-family.mono}",
      "font-variant-numeric": { "value": "tabular-nums" },
      "usage": "Цены (12 800 ₽), ID заявок, slug, размеры объектов. Всегда tabular-nums чтобы числа не прыгали в таблицах."
    }
  }
}
